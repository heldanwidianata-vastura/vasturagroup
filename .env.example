# ── Firebase ──────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ── Firestore ─────────────────────────────────────────────────────────
VITE_FS_COLLECTION=nama_collection_firestore

# ── Cloudinary ────────────────────────────────────────────────────────
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# ── EmailJS ───────────────────────────────────────────────────────────
VITE_EMAILJS_PUBLIC_KEY=your_public_key
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id

# ── Admin Credentials (default login) ────────────────────────────────
VITE_ADMIN_PASSWORD=ganti_password_aman
VITE_WRITER_PASSWORD=ganti_password_aman
VITE_CS_PASSWORD=ganti_password_aman

# ── Contact Defaults ──────────────────────────────────────────────────
VITE_DEFAULT_EMAIL=email@domain.com
VITE_DEFAULT_PHONE=+62 8xx xxxx xxxx
VITE_DEFAULT_ADDRESS=Kota, Provinsi, Indonesia
VITE_WA_ADMIN1=628xxxxxxxxxx
VITE_WA_ADMIN2=628xxxxxxxxxx
VITE_IG_LINK=https://instagram.com/username
VITE_FB_LINK=https://facebook.com/username

# ── Session ───────────────────────────────────────────────────────────
VITE_SESSION_KEY=nama_session_key
